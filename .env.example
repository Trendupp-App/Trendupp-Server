# Application Setup
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=trendupp_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Logtail / Betterstack Configuration
BETTERSTACK_SOURCE_TOKEN=

# AWS Configuration (S3 & SES)
AWS_S3_REGION=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_BUCKET=
AWS_SES_REGION=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_FROM_EMAIL=

# Security Config
ALLOWED_ORIGINS=*
JWT_SECRET=trendupp-default-secret-key-for-development-and-testing
JWT_EXPIRES_IN=24h
ONBOARDING_API_KEY=trendupp-default-onboarding-api-key-for-development-and-testing

# Google Social Auth
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=

# TikTok Social Auth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Instagram Social Auth
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
