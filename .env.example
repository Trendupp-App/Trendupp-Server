# Application settings
PORT=3000
NODE_ENV=development

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=trendupp_db

# Redis configuration (for task queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Logtail / BetterStack integration (optional)
BETTERSTACK_SOURCE_TOKEN=

# AWS settings (optional, for S3 uploads and SES email sending)
AWS_S3_REGION=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_BUCKET=
AWS_SES_REGION=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_FROM_EMAIL=

# Security configurations
ALLOWED_ORIGINS=*
JWT_SECRET=trendupp-default-secret-key-for-development-and-testing
JWT_EXPIRES_IN=24h
ONBOARDING_API_KEY=trendupp-default-onboarding-api-key-for-development-and-testing
